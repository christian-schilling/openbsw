image = :[
    :/docker::Dockerfile.dev
    ::test/pyTest/requirements.txt
    ::tools/UdsTool/
]
run = :[
    :/ws::run.sh:replace(
        "CMAKE_PRESET":"tests-posix-debug"
        "EXEC":"ctest --preset tests-posix-debug"
    )
    ::CMakePresets.json
    ::CMakeLists.txt
    ::cmake/
    ::platforms/posix/
    ::platforms/CMakeLists.txt
    libs = :/libs:[
        ::CMakeLists.txt
        ::3rdparty/CMakeLists.txt
        ::3rdparty/etl/
        ::3rdparty/googletest/
        ::3rdparty/freeRtos/
        ::3rdparty/lwip/
        ::3rdparty/printf/
        ::bsp/
        bsw = :/bsw:[
            ::asyncFreeRtos/freeRtosConfiguration/
            ::CMakeLists.txt
            ::*/CMakeLists.txt
            ::*/include/**/*.h
            ::*/mock/**/*.*
            ::*/test/**/*.*
            ::*/examples/**/*.*
            ::*/src/**/*.cpp
        ]
        safety = :/safety:[
            ::CMakeLists.txt
            ::*/CMakeLists.txt
            ::*/include/**/*.h
            ::*/src/**/*.cpp
            ::*/mock/**/*.*
            ::*/test/**/*.*
        ]
    ]
    ::executables/unitTest/
]
